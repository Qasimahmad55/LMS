<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Confirmation</title>
    <style>
        /* Reset */
        body,
        table,
        td,
        p,
        a {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            width: 100% !important;
            background-color: #f4f7fb;
            color: #1f2937;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        a {
            text-decoration: none;
        }

        .container {
            width: 100%;
            padding: 32px 12px;
            background-color: #f4f7fb;
        }

        .card {
            max-width: 620px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
            box-shadow: 0 6px 22px rgba(17, 24, 39, 0.08);
        }

        .header {
            background: linear-gradient(135deg, #0f62fe 0%, #2563eb 100%);
            color: #ffffff;
            text-align: center;
            padding: 28px 24px;
        }

        .brand {
            font-size: 14px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            opacity: 0.9;
            margin-bottom: 8px;
        }

        .header h1 {
            font-size: 26px;
            line-height: 1.25;
            margin: 0;
            font-weight: 700;
        }

        .body {
            padding: 28px 28px 18px;
        }

        .text {
            font-size: 15px;
            line-height: 1.7;
            color: #374151;
            margin-bottom: 14px;
            text-align: center;
        }

        .details {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px;
            margin: 18px 0;
        }

        .details h3 {
            margin: 0 0 12px;
            font-size: 16px;
            font-weight: 700;
            color: #0f62fe;
            text-align: center;
        }

        .table {
            width: 100%;
            font-size: 14px;
            color: #111827;
        }

        .table td {
            padding: 8px 0;
        }

        .table td:first-child {
            color: #6b7280;
            width: 40%;
        }

        .total {
            border-top: 1px solid #e5e7eb;
            margin-top: 10px;
            padding-top: 10px;
            font-size: 15px;
            font-weight: 700;
            text-align: right;
            color: #111827;
        }

        .cta-wrap {
            text-align: center;
            margin: 20px 0 6px;
        }

        .button {
            display: inline-block;
            background: #0f62fe;
            color: #ffffff !important;
            padding: 12px 22px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        .footer {
            border-top: 1px solid #e5e7eb;
            background: #f9fafb;
            padding: 18px 28px 24px;
            font-size: 13px;
            color: #6b7280;
            line-height: 1.7;
            text-align: center;
        }

        .footer a {
            color: #0f62fe;
        }

        @media only screen and (max-width: 600px) {
            .header h1 {
                font-size: 22px;
            }

            .body,
            .footer {
                padding-left: 18px;
                padding-right: 18px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <div class="brand">ELearning</div>
                <h1>Your Order is Confirmed</h1>
            </div>

            <div class="body">
                <p class="text">
                    Thanks for your purchase! Here are your order details:
                </p>

                <div class="details">
                    <h3>Order Details</h3>
                    <table class="table">
                        <tr>
                            <td>Order #</td>
                            <td>
                                <%= order._id %>
                            </td>
                        </tr>
                        <tr>
                            <td>Order Date</td>
                            <td>
                                <%= order.date %>
                            </td>
                        </tr>
                        <tr>
                            <td>Item</td>
                            <td>
                                <%= order.name %>
                            </td>
                        </tr>
                        <tr>
                            <td>Quantity</td>
                            <td>1</td>
                        </tr>
                        <tr>
                            <td>Price</td>
                            <td>$<%= order.price %>
                            </td>
                        </tr>
                    </table>

                    <div class="total">Total: $<%= order.price %>
                    </div>
                </div>

            </div>

            <div class="footer">
                Need help? Contact us at
                <a href="mailto:support@taimoor_service.com">support@lms.com</a><br />
                © <%= new Date().getFullYear() %> ELearning. All rights reserved.
            </div>
        </div>
    </div>
</body>

</html>