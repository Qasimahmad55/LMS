<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Activate Your ELearning Account</title>
    <style>
        /* Reset */
        body,
        table,
        td,
        p,
        a {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            width: 100% !important;
            background-color: #f4f7fb;
            color: #1f2937;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        a {
            text-decoration: none;
        }

        .container {
            width: 100%;
            padding: 32px 12px;
            background-color: #f4f7fb;
        }

        .card {
            max-width: 620px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
            box-shadow: 0 6px 22px rgba(17, 24, 39, 0.08);
        }

        .header {
            background: linear-gradient(135deg, #0f62fe 0%, #2563eb 100%);
            color: #ffffff;
            text-align: center;
            padding: 30px 24px;
        }

        .brand {
            font-size: 14px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            opacity: 0.9;
            margin-bottom: 8px;
        }

        .header h1 {
            font-size: 28px;
            line-height: 1.25;
            margin: 0;
            font-weight: 700;
        }

        .body {
            padding: 30px 28px 22px;
        }

        .greeting {
            font-size: 18px;
            line-height: 1.5;
            margin-bottom: 16px;
        }

        .name {
            color: #0f62fe;
            font-weight: 700;
        }

        .text {
            font-size: 15px;
            line-height: 1.7;
            color: #374151;
            margin-bottom: 16px;
        }

        .code-wrap {
            background: #f8fafc;
            border: 1px dashed #93c5fd;
            border-radius: 10px;
            text-align: center;
            padding: 18px;
            margin: 20px 0;
        }

        .code-label {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 8px;
            letter-spacing: 0.4px;
        }

        .code {
            font-size: 30px;
            font-weight: 800;
            letter-spacing: 6px;
            color: #111827;
        }

        .note {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            color: #1e3a8a;
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 14px;
            line-height: 1.5;
            margin: 18px 0 6px;
        }

        .cta-wrap {
            text-align: center;
            margin: 22px 0 12px;
        }

        .button {
            display: inline-block;
            background: #0f62fe;
            color: #ffffff !important;
            padding: 12px 22px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        .footer {
            border-top: 1px solid #e5e7eb;
            background: #f9fafb;
            padding: 18px 28px 24px;
            font-size: 13px;
            color: #6b7280;
            line-height: 1.7;
        }

        .footer a {
            color: #0f62fe;
        }

        @media only screen and (max-width: 600px) {
            .header h1 {
                font-size: 24px;
            }

            .body,
            .footer {
                padding-left: 18px;
                padding-right: 18px;
            }

            .code {
                font-size: 24px;
                letter-spacing: 4px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <div class="brand">ELearning</div>
                <h1>Activate Your Account</h1>
            </div>

            <div class="body">
                <p class="greeting">
                    Hello, <span class="name">
                        <%= user.name %>
                    </span> 👋
                </p>

                <p class="text">
                    Thank you for registering with <strong>ELearning</strong>. To complete your
                    signup, please use the verification code below:
                </p>

                <div class="code-wrap">
                    <div class="code-label">YOUR ACTIVATION CODE</div>
                    <div class="code">
                        <%= activationCode %>
                    </div>
                </div>

                <div class="note">
                    This code is valid for <strong>5 minutes</strong>. Please do not share it with anyone.
                </div>



                <p class="text" style="margin-top: 18px;">
                    If you did not create an ELearning account, you can safely ignore this email.
                </p>
            </div>

            <div class="footer">
                Need help? Contact us at
                <a href="mailto:support@becodemy.com">support@elearning.com</a><br />
                © <%= new Date().getFullYear() %> ELearning. All rights reserved.
            </div>
        </div>
    </div>
</body>

</html>