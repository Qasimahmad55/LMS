<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Reply Notification</title>
    <style>
        /* Reset */
        body,
        table,
        td,
        p,
        a {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            width: 100% !important;
            background-color: #f4f7fb;
            color: #1f2937;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        a {
            text-decoration: none;
        }

        .container {
            width: 100%;
            padding: 32px 12px;
            background-color: #f4f7fb;
        }

        .card {
            max-width: 620px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
            box-shadow: 0 6px 22px rgba(17, 24, 39, 0.08);
        }

        .header {
            background: linear-gradient(135deg, #0f62fe 0%, #2563eb 100%);
            color: #ffffff;
            text-align: center;
            padding: 28px 24px;
        }

        .brand {
            font-size: 14px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            opacity: 0.9;
            margin-bottom: 8px;
        }

        .header h1 {
            font-size: 26px;
            line-height: 1.25;
            margin: 0;
            font-weight: 700;
        }

        .body {
            padding: 28px 28px 18px;
        }

        .greeting {
            font-size: 18px;
            line-height: 1.5;
            margin-bottom: 14px;
        }

        .name {
            color: #0f62fe;
            font-weight: 700;
        }

        .text {
            font-size: 15px;
            line-height: 1.7;
            color: #374151;
            margin-bottom: 14px;
        }

        .highlight {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 14px 14px;
            margin: 18px 0;
        }

        .label {
            font-size: 12px;
            color: #6b7280;
            letter-spacing: 0.4px;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .video-title {
            font-size: 16px;
            font-weight: 700;
            color: #111827;
        }

        .cta-wrap {
            text-align: center;
            margin: 20px 0 8px;
        }

        .button {
            display: inline-block;
            background: #0f62fe;
            color: #ffffff !important;
            padding: 12px 22px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        .hint {
            font-size: 12.5px;
            color: #6b7280;
            line-height: 1.6;
            margin-top: 10px;
            text-align: center;
        }

        .footer {
            border-top: 1px solid #e5e7eb;
            background: #f9fafb;
            padding: 18px 28px 24px;
            font-size: 13px;
            color: #6b7280;
            line-height: 1.7;
        }

        .footer a {
            color: #0f62fe;
        }

        @media only screen and (max-width: 600px) {
            .header h1 {
                font-size: 22px;
            }

            .body,
            .footer {
                padding-left: 18px;
                padding-right: 18px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <div class="brand">ELearning</div>
                <h1>New Reply to Your Question</h1>
            </div>

            <div class="body">
                <p class="greeting">Hello, <span class="name">
                        <%= name %>
                    </span></p>

                <p class="text">
                    A new reply has been posted to your question in the following video:
                </p>

                <div class="highlight">
                    <div class="label">Video</div>
                    <div class="video-title">"<%= title %>"</div>
                </div>

                <p class="text">
                    Please log in to your account to view the reply and continue the
                    discussion.
                </p>

                <p class="text" style="margin-top: 16px">
                    Thank you for being a part of our community.
                </p>
            </div>

            <div class="footer">
                Need help? Contact us at
                <a href="mailto:support@becodemy.com">support@becodemy.com</a><br />
                © <%= new Date().getFullYear() %> ELearning. All rights reserved.
            </div>
        </div>
    </div>
</body>

</html>